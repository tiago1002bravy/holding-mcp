{
  "name": "holding-mcp",
  "version": "0.1.0",
  "description": "Servidor MCP (stdio) do Holding Manager — cadastro de famílias, membros, imóveis, empresas, estratégia, minutas e cláusulas via API REST.",
  "type": "module",
  "bin": {
    "holding-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "start:http": "node build/http.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "holding-manager",
    "claude"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "typescript": "^5.6.0"
  }
}
